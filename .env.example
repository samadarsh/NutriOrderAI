# App configuration
APP_ENV=development
USE_MOCK_MCP=true
SWIGGY_ENV=mock

# Database configuration
DATABASE_URL=sqlite:///./nutriorder.db

# Encrypted session key (32 bytes or 64 hex characters)
ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

# Swiggy Staging/Production configurations
SWIGGY_MCP_BASE_URL=https://mcp-staging.swiggy.com/food
SWIGGY_TOKEN=
SWIGGY_AUTH_URL=https://mcp.swiggy.com/auth/authorize
SWIGGY_TOKEN_URL=https://mcp.swiggy.com/auth/token
SWIGGY_CLIENT_ID=
SWIGGY_CLIENT_SECRET=
SWIGGY_REDIRECT_URI=http://localhost:8000/auth/swiggy/callback
ALLOW_PLACE_ORDER=false
FRONTEND_BASE_URL=http://localhost:3000
GOOGLE_CLIENT_ID=

# CORS Configuration (comma-separated list of origins)
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001
